    {
        "mcpServers": {
            "google-researcher": {
                "command": "npx",
                "args": [
                    "-y",
                    "google-researcher-mcp"
                ],
                "env": {
                    "GOOGLE_CUSTOM_SEARCH_API_KEY": "YOUR_API_KEY_HERE",
                    "GOOGLE_CUSTOM_SEARCH_ID": "YOUR_SEARCH_ID_HERE"
                }
            },
            "youtube-transcript": {
                "command": "npx",
                "args": [
                    "-y",
                    "@kimtaeyoon83/mcp-server-youtube-transcript"
                ]
            }
        }
    }